# ════════════════════════════════════════════════════════════════════════════
#  AgentFlow AI — Backend Environment Variables
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="AgentFlow AI"
APP_VERSION="1.0.0"
ENVIRONMENT="development"           # development | staging | production
DEBUG=true
SECRET_KEY="change-this-to-a-very-long-random-secret-key-at-least-64-chars"

# ── Server ────────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000
WORKERS=1                           # uvicorn worker count (increase in prod)
RELOAD=true                         # hot-reload (dev only — set false in prod)

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="agentflow"
POSTGRES_USER="agentflow_user"
POSTGRES_PASSWORD="change-this-password"

# Assembled automatically in settings.py — you can override if needed
# DATABASE_URL="postgresql+asyncpg://user:password@host:5432/dbname"
# SYNC_DATABASE_URL="postgresql+psycopg2://user:password@host:5432/dbname"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""                   # leave empty if no auth
# REDIS_URL="redis://:password@localhost:6379/0"

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET_KEY="change-this-to-another-long-random-secret-key-for-jwt"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Groq API ─────────────────────────────────────────────────────────────────
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_FAST_MODEL="llama-3.1-8b-instant"

# ── HuggingFace Embeddings (local — no API key needed) ────────────────────────
EMBEDDING_MODEL_NAME="sentence-transformers/all-mpnet-base-v2"
EMBEDDING_DIMENSION=768

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS="pdf,docx,txt"
UPLOAD_DIR="./uploads"              # local storage path (Phase 1)

# ── RAG / Chunking ────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=8
RETRIEVAL_SIMILARITY_THRESHOLD=0.70

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100            # max requests per window
RATE_LIMIT_WINDOW_SECONDS=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="DEBUG"                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"                  # json | console
LOG_FILE=""                        # optional: path to log file (empty = stdout only)

# ── Web Search (Phase 3) ──────────────────────────────────────────────────────
TAVILY_API_KEY="your-tavily-api-key-here"
